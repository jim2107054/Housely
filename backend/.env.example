# ──────────────────────────────────────────
# Housely Backend — Environment Variables
# Copy this to .env and fill in your values
# ──────────────────────────────────────────

NODE_ENV=development
PORT=3000

# ──────────────────────────────────────────
# DATABASE — Neon (Hosted PostgreSQL)
# Get both URLs from: https://console.neon.tech
# ──────────────────────────────────────────
DATABASE_URL="postgresql://neondb_owner:<password>@<endpoint-pooler>.ap-southeast-1.aws.neon.tech/neondb?sslmode=require&pgbouncer=true"
DIRECT_URL="postgresql://neondb_owner:<password>@<endpoint>.ap-southeast-1.aws.neon.tech/neondb?sslmode=require"

# ──────────────────────────────────────────
# JWT
# ──────────────────────────────────────────
JWT_ACCESS_SECRET=your-access-secret-here
JWT_REFRESH_SECRET=your-refresh-secret-here
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ──────────────────────────────────────────
# REDIS (optional — falls back to in-memory)
# ──────────────────────────────────────────
# REDIS_URL=redis://localhost:6379

# ──────────────────────────────────────────
# EMAIL (Gmail + App Password or SendGrid)
# ──────────────────────────────────────────
# EMAIL_USER=your-email@gmail.com
# EMAIL_PASS=your-app-password
# SENDGRID_API_KEY=SG.your_sendgrid_api_key
# EMAIL_FROM=no-reply@housely.app

# ──────────────────────────────────────────
# TWILIO (SMS / OTP)
# ──────────────────────────────────────────
# TWILIO_ACCOUNT_SID=your-sid
# TWILIO_AUTH_TOKEN=your-token
# TWILIO_PHONE_NUMBER=+1234567890

# ──────────────────────────────────────────
# CLOUDINARY (Image uploads)
# ──────────────────────────────────────────
# CLOUDINARY_CLOUD_NAME=your-cloud-name
# CLOUDINARY_API_KEY=your-api-key
# CLOUDINARY_API_SECRET=your-api-secret

# ──────────────────────────────────────────
# FIREBASE (FCM Push Notifications)
# ──────────────────────────────────────────
# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com

# ──────────────────────────────────────────
# PAYMENT (SSLCommerz) - For future use
# ──────────────────────────────────────────
# SSLCOMMERZ_STORE_ID=your_store_id
# SSLCOMMERZ_STORE_PASSWORD=your_store_password
# SSLCOMMERZ_IS_LIVE=false

# ──────────────────────────────────────────
# APP
# ──────────────────────────────────────────
APP_URL=http://localhost:3000
FRONTEND_DEEP_LINK_BASE=housely://house

