# ──────────────────────────────────────────
# Housely Backend — Environment Variables
# Copy this to .env and fill in your values
# ──────────────────────────────────────────

NODE_ENV=development
PORT=3000

# ──────────────────────────────────────────
# DATABASE — Neon (Hosted PostgreSQL)
# Get both URLs from: https://console.neon.tech
# ──────────────────────────────────────────
DATABASE_URL="postgresql://neondb_owner:<password>@<endpoint-pooler>.ap-southeast-1.aws.neon.tech/neondb?sslmode=require&pgbouncer=true"
DIRECT_URL="postgresql://neondb_owner:<password>@<endpoint>.ap-southeast-1.aws.neon.tech/neondb?sslmode=require"

# ──────────────────────────────────────────
# JWT
# ──────────────────────────────────────────
JWT_ACCESS_SECRET=your-access-secret-here
JWT_REFRESH_SECRET=your-refresh-secret-here
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ──────────────────────────────────────────
# REDIS (optional — falls back to in-memory)
# ──────────────────────────────────────────
# REDIS_URL=redis://localhost:6379

# ──────────────────────────────────────────
# EMAIL (Gmail + App Password)
# ──────────────────────────────────────────
# EMAIL_USER=your-email@gmail.com
# EMAIL_PASS=your-app-password

# ──────────────────────────────────────────
# TWILIO (SMS / OTP)
# ──────────────────────────────────────────
# TWILIO_ACCOUNT_SID=your-sid
# TWILIO_AUTH_TOKEN=your-token
# TWILIO_PHONE_NUMBER=+1234567890

# ──────────────────────────────────────────
# CLOUDINARY (Image uploads)
# ──────────────────────────────────────────
# CLOUDINARY_CLOUD_NAME=your-cloud-name
# CLOUDINARY_API_KEY=your-api-key
# CLOUDINARY_API_SECRET=your-api-secret
