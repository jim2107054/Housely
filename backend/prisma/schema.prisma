datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ─── Enums ──────────────────────────────────────────────

enum Role {
  USER
  AGENT
  ADMIN
}

enum AuthProvider {
  LOCAL
  GOOGLE
  FACEBOOK
}

enum HouseStatus {
  AVAILABLE
  UNAVAILABLE
}

enum ListingType {
  RENT
  SALE
}

enum PropertyType {
  APARTMENT
  PENTHOUSE
  HOTEL
  VILLA
  STUDIO
  DUPLEX
  TOWNHOUSE
  CONDO
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

// ─── Models ─────────────────────────────────────────────

model User {
  id           String       @id @default(cuid())
  username     String       @unique
  email        String       @unique
  password     String?
  phoneNumber  String?      @unique
  name         String?
  bio          String?
  dateOfBirth  DateTime?
  avatar       String?
  role         Role         @default(USER)
  authProvider AuthProvider @default(LOCAL)
  googleId     String?      @unique
  facebookId   String?      @unique
  isVerified   Boolean      @default(false)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  savedLocations        SavedLocation[]
  houses                House[]              @relation("AgentHouses")
  houseViews            HouseView[]
  favorites             Favorite[]
  notificationSettings  NotificationSettings?
  payments              Payment[]
  bookings              Booking[]            @relation("UserBookings")
  agentBookings         Booking[]            @relation("AgentBookings")
  reviews               Review[]
  userConversations     Conversation[]       @relation("UserConversations")
  agentConversations    Conversation[]       @relation("AgentConversations")
  messages              Message[]
  notifications         Notification[]
  deviceTokens          DeviceToken[]
}

model SavedLocation {
  id        String   @id @default(cuid())
  userId    String
  label     String?
  address   String
  city      String?
  area      String?
  street    String?
  latitude  Float
  longitude Float
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model House {
  id           String       @id @default(cuid())
  name         String
  description  String?
  status       HouseStatus  @default(AVAILABLE)
  rentPerMonth Float?
  salePrice    Float?
  listingType  ListingType
  propertyType PropertyType
  address      String
  city         String
  area         String?
  latitude     Float?
  longitude    Float?
  bedrooms     Int          @default(1)
  bathrooms    Int          @default(1)
  sizeInSqft   Float?
  buildYear    Int?
  hasWifi      Boolean      @default(false)
  hasWater     Boolean      @default(true)
  agentId      String
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  agent            User           @relation("AgentHouses", fields: [agentId], references: [id])
  images           HouseImage[]
  video            HouseVideo?
  publicFacilities PublicFacility?
  views            HouseView[]
  favorites        Favorite[]
  bookings         Booking[]
  reviews          Review[]
  conversations    Conversation[]

  @@index([agentId])
  @@index([city])
  @@index([listingType])
  @@index([propertyType])
  @@index([status])
}

model HouseImage {
  id      String @id @default(cuid())
  houseId String
  url     String
  order   Int    @default(0)

  house House @relation(fields: [houseId], references: [id], onDelete: Cascade)

  @@index([houseId])
}

model HouseVideo {
  id      String @id @default(cuid())
  houseId String @unique
  url     String

  house House @relation(fields: [houseId], references: [id], onDelete: Cascade)
}

model PublicFacility {
  id                   String @id @default(cuid())
  houseId              String @unique
  wifi                 Boolean @default(false)
  water                Boolean @default(false)
  electricity          Boolean @default(false)
  parking              Boolean @default(false)
  mosqueDistance        Float?
  hospitalDistance      Float?
  shoppingMallDistance  Float?
  marketDistance        Float?

  house House @relation(fields: [houseId], references: [id], onDelete: Cascade)
}

model HouseView {
  id       String   @id @default(cuid())
  userId   String
  houseId  String
  viewedAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  house House @relation(fields: [houseId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([houseId])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  houseId   String
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  house House @relation(fields: [houseId], references: [id], onDelete: Cascade)

  @@unique([userId, houseId])
}

model NotificationSettings {
  id             String  @id @default(cuid())
  userId         String  @unique
  pushEnabled    Boolean @default(true)
  emailEnabled   Boolean @default(true)
  smsEnabled     Boolean @default(false)
  bookingUpdates Boolean @default(true)
  promotions     Boolean @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Payment {
  id            String        @id @default(cuid())
  userId        String
  bookingId     String?
  amount        Float
  currency      String        @default("BDT")
  method        String?
  transactionId String?       @unique
  gatewayResponse String?
  status        PaymentStatus @default(PENDING)
  description   String?
  createdAt     DateTime      @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  booking Booking? @relation(fields: [bookingId], references: [id])

  @@index([userId])
  @@index([bookingId])
}

// ─── Booking ────────────────────────────────────────────

enum BookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

model Booking {
  id           String        @id @default(cuid())
  userId       String
  houseId      String
  agentId      String
  checkIn      DateTime
  checkOut     DateTime
  totalAmount  Float
  status       BookingStatus @default(PENDING)
  paymentStatus PaymentStatus @default(PENDING)
  notes        String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  user     User      @relation("UserBookings", fields: [userId], references: [id], onDelete: Cascade)
  house    House     @relation(fields: [houseId], references: [id], onDelete: Cascade)
  agent    User      @relation("AgentBookings", fields: [agentId], references: [id])
  payments Payment[]
  review   Review?

  @@index([userId])
  @@index([houseId])
  @@index([agentId])
  @@index([status])
}

// ─── Review ─────────────────────────────────────────────

model Review {
  id        String   @id @default(cuid())
  userId    String
  houseId   String
  bookingId String   @unique
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  house   House         @relation(fields: [houseId], references: [id], onDelete: Cascade)
  booking Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  media   ReviewMedia[]

  @@index([userId])
  @@index([houseId])
}

model ReviewMedia {
  id       String @id @default(cuid())
  reviewId String
  url      String
  type     String @default("image") // image | video

  review Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@index([reviewId])
}

// ─── Messaging ──────────────────────────────────────────

model Conversation {
  id        String    @id @default(cuid())
  userId    String
  agentId   String
  houseId   String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user     User      @relation("UserConversations", fields: [userId], references: [id], onDelete: Cascade)
  agent    User      @relation("AgentConversations", fields: [agentId], references: [id], onDelete: Cascade)
  house    House?    @relation(fields: [houseId], references: [id])
  messages Message[]

  @@unique([userId, agentId])
  @@index([userId])
  @@index([agentId])
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  senderId       String
  content        String
  type           String   @default("text") // text | image | audio | video
  isRead         Boolean  @default(false)
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([senderId])
}

// ─── Notifications ──────────────────────────────────────

enum NotificationType {
  BOOKING_CONFIRMED
  BOOKING_CANCELLED
  PAYMENT_SUCCESS
  NEW_MESSAGE
  REVIEW_POSTED
  GENERAL
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  data      Json?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
}

model DeviceToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  platform  String   @default("android") // android | ios
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
