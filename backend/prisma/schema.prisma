generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                               String                @id @default(cuid())
  username                         String                @unique
  email                            String                @unique
  password                         String?
  phoneNumber                      String?               @unique
  name                             String?
  bio                              String?
  dateOfBirth                      DateTime?
  avatar                           String?
  role                             Role                  @default(USER)
  authProvider                     AuthProvider          @default(LOCAL)
  googleId                         String?               @unique
  facebookId                       String?               @unique
  isVerified                       Boolean               @default(false)
  createdAt                        DateTime              @default(now())
  updatedAt                        DateTime              @updatedAt
  clerkId                          String?               @unique
  agentBookings                    Booking[]             @relation("AgentBookings")
  bookings                         Booking[]             @relation("UserBookings")
  Contract_Contract_ownerIdToUser  Contract[]            @relation("Contract_ownerIdToUser")
  Contract_Contract_renterIdToUser Contract[]            @relation("Contract_renterIdToUser")
  agentConversations               Conversation[]        @relation("AgentConversations")
  userConversations                Conversation[]        @relation("UserConversations")
  deviceTokens                     DeviceToken[]
  favorites                        Favorite[]
  houses                           House[]               @relation("AgentHouses")
  houseViews                       HouseView[]
  messages                         Message[]
  notifications                    Notification[]
  notificationSettings             NotificationSettings?
  payments                         Payment[]
  reviews                          Review[]
  savedLocations                   SavedLocation[]
  UserKYC                          UserKYC?
}

model SavedLocation {
  id        String   @id @default(cuid())
  userId    String
  label     String?
  address   String
  city      String?
  area      String?
  street    String?
  latitude  Float
  longitude Float
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model House {
  id               String          @id @default(cuid())
  name             String
  description      String?
  status           HouseStatus     @default(AVAILABLE)
  rentPerMonth     Float?
  salePrice        Float?
  listingType      ListingType
  propertyType     PropertyType
  address          String
  city             String
  area             String?
  latitude         Float?
  longitude        Float?
  bedrooms         Int             @default(1)
  bathrooms        Int             @default(1)
  sizeInSqft       Float?
  buildYear        Int?
  hasWifi          Boolean         @default(false)
  hasWater         Boolean         @default(true)
  agentId          String
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  bookings         Booking[]
  Contract         Contract[]
  conversations    Conversation[]
  favorites        Favorite[]
  agent            User            @relation("AgentHouses", fields: [agentId], references: [id])
  images           HouseImage[]
  video            HouseVideo?
  views            HouseView[]
  publicFacilities PublicFacility?
  reviews          Review[]

  @@index([agentId])
  @@index([city])
  @@index([listingType])
  @@index([propertyType])
  @@index([status])
}

model HouseImage {
  id      String @id @default(cuid())
  houseId String
  url     String
  order   Int    @default(0)
  house   House  @relation(fields: [houseId], references: [id], onDelete: Cascade)

  @@index([houseId])
}

model HouseVideo {
  id      String @id @default(cuid())
  houseId String @unique
  url     String
  house   House  @relation(fields: [houseId], references: [id], onDelete: Cascade)
}

model PublicFacility {
  id                   String  @id @default(cuid())
  houseId              String  @unique
  wifi                 Boolean @default(false)
  water                Boolean @default(false)
  electricity          Boolean @default(false)
  parking              Boolean @default(false)
  mosqueDistance       Float?
  hospitalDistance     Float?
  shoppingMallDistance Float?
  marketDistance       Float?
  house                House   @relation(fields: [houseId], references: [id], onDelete: Cascade)
}

model HouseView {
  id       String   @id @default(cuid())
  userId   String
  houseId  String
  viewedAt DateTime @default(now())
  house    House    @relation(fields: [houseId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([houseId])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  houseId   String
  createdAt DateTime @default(now())
  house     House    @relation(fields: [houseId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, houseId])
}

model NotificationSettings {
  id             String  @id @default(cuid())
  userId         String  @unique
  pushEnabled    Boolean @default(true)
  emailEnabled   Boolean @default(true)
  smsEnabled     Boolean @default(false)
  bookingUpdates Boolean @default(true)
  promotions     Boolean @default(false)
  user           User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Payment {
  id              String        @id @default(cuid())
  userId          String
  bookingId       String?
  amount          Float
  currency        String        @default("BDT")
  method          String?
  transactionId   String?       @unique
  gatewayResponse String?
  status          PaymentStatus @default(PENDING)
  description     String?
  createdAt       DateTime      @default(now())
  booking         Booking?      @relation(fields: [bookingId], references: [id])
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([bookingId])
}

model Booking {
  id            String        @id @default(cuid())
  userId        String
  houseId       String
  agentId       String
  checkIn       DateTime
  checkOut      DateTime
  totalAmount   Float
  status        BookingStatus @default(PENDING)
  paymentStatus PaymentStatus @default(PENDING)
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  agent         User          @relation("AgentBookings", fields: [agentId], references: [id])
  house         House         @relation(fields: [houseId], references: [id], onDelete: Cascade)
  user          User          @relation("UserBookings", fields: [userId], references: [id], onDelete: Cascade)
  Contract      Contract?
  payments      Payment[]
  review        Review?

  @@index([userId])
  @@index([houseId])
  @@index([agentId])
  @@index([status])
}

model Review {
  id        String        @id @default(cuid())
  userId    String
  houseId   String
  bookingId String        @unique
  rating    Int
  comment   String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  booking   Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  house     House         @relation(fields: [houseId], references: [id], onDelete: Cascade)
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  media     ReviewMedia[]

  @@index([userId])
  @@index([houseId])
}

model ReviewMedia {
  id       String @id @default(cuid())
  reviewId String
  url      String
  type     String @default("image")
  review   Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@index([reviewId])
}

model Conversation {
  id        String    @id @default(cuid())
  userId    String
  agentId   String
  houseId   String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  agent     User      @relation("AgentConversations", fields: [agentId], references: [id], onDelete: Cascade)
  house     House?    @relation(fields: [houseId], references: [id])
  user      User      @relation("UserConversations", fields: [userId], references: [id], onDelete: Cascade)
  messages  Message[]

  @@unique([userId, agentId])
  @@index([userId])
  @@index([agentId])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  senderId       String
  content        String
  type           String       @default("text")
  isRead         Boolean      @default(false)
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([senderId])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  data      Json?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
}

model DeviceToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  platform  String   @default("android")
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Contract {
  id                           String         @id
  bookingId                    String         @unique
  renterId                     String
  ownerId                      String
  houseId                      String
  content                      Json
  status                       ContractStatus @default(ACTIVE)
  createdAt                    DateTime       @default(now())
  Booking                      Booking        @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  House                        House          @relation(fields: [houseId], references: [id])
  User_Contract_ownerIdToUser  User           @relation("Contract_ownerIdToUser", fields: [ownerId], references: [id])
  User_Contract_renterIdToUser User           @relation("Contract_renterIdToUser", fields: [renterId], references: [id])

  @@index([ownerId])
  @@index([renterId])
}

model UserKYC {
  id                String    @id
  userId            String    @unique
  documentType      String    @default("nid")
  documentFront     String
  documentBack      String?
  selfie            String
  status            KYCStatus @default(PENDING)
  rejectionNote     String?
  onfidoApplicantId String?
  onfidoCheckId     String?
  submittedAt       DateTime  @default(now())
  reviewedAt        DateTime?
  User              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum Role {
  USER
  AGENT
  ADMIN
}

enum AuthProvider {
  LOCAL
  GOOGLE
  FACEBOOK
}

enum HouseStatus {
  AVAILABLE
  UNAVAILABLE
}

enum ListingType {
  RENT
  SALE
}

enum PropertyType {
  APARTMENT
  PENTHOUSE
  HOTEL
  VILLA
  STUDIO
  DUPLEX
  TOWNHOUSE
  CONDO
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

enum NotificationType {
  BOOKING_CONFIRMED
  BOOKING_CANCELLED
  PAYMENT_SUCCESS
  NEW_MESSAGE
  REVIEW_POSTED
  GENERAL
}

enum ContractStatus {
  ACTIVE
  TERMINATED
}

enum KYCStatus {
  PENDING
  APPROVED
  REJECTED
}
